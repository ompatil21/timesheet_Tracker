# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# LOCAL: docker-compose up -d, then use:
MONGO_URI=mongodb://127.0.0.1:27017/timesheet-tracker-local
# PRODUCTION: set on hosting platform, never commit the real value

# JWT Configuration — generate a strong random secret (e.g. openssl rand -hex 32)
JWT_SECRET=replace_with_a_long_random_string

# Frontend Configuration (for CORS)
FRONTEND_URL=http://localhost:3000

# API Rate Limiting (in requests per 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
